{
  "name": "project-template-front",
  "version": "2.16.1",
  "license": "MIT",
  "author": "New York Style",
  "type": "module",
  "scripts": {
    "dev": "pnpm run generate:tokens && vite",
    "build": "pnpm run generate:tokens && vite build",
    "build:analyze": "cross-env ANALYZE=true pnpm run build",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,md,mdx,css,yaml}\"",
    "prettier:format": "prettier --write \"**/*.{ts,tsx,js,md,mdx,css,yaml}\"",
    "lint": "eslint .",
    "generate:tokens": "pnpx tsx tools/generators/generate-global-scss.ts",
    "semantic-release": "semantic-release",
    "semantic-release:dry-run": "semantic-release --dry-run",
    "codestyle:check": "pnpm run prettier:check && pnpm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "pnpm exec playwright test",
    "e2e:changed": "node e2e/scripts/select-tests.mjs",
    "allure:show": "pnpm exec allure serve allure-results",
    "generate:api": "pnpm exec orval",
    "type:check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpx pretty-quick --staged",
      "pnpm exec eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "private": true,
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@new_york_style/project-template-ui": "1.2.1",
    "@tanstack/react-query": "5.90.5",
    "@tanstack/react-query-devtools": "5.90.2",
    "antd": "6.0.0",
    "axios": "1.14.0",
    "i18next": "25.5.2",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-http-backend": "3.0.2",
    "js-cookie": "3.0.5",
    "lodash-es": "4.18.1",
    "mobx": "6.15.0",
    "mobx-react-lite": "4.1.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-error-boundary": "6.0.0",
    "react-helmet": "6.1.0",
    "react-hook-form": "7.72.0",
    "react-hook-form-antd": "1.1.5",
    "react-i18next": "16.0.0",
    "react-router": "7.14.0",
    "react-router-dom": "7.14.0",
    "web-vitals": "5.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.37.0",
    "@playwright/test": "1.56.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/js-cookie": "3.0.6",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.7.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.1",
    "@types/react-helmet": "6.1.11",
    "@typescript-eslint/eslint-plugin": "8.46.0",
    "@typescript-eslint/parser": "8.46.0",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/coverage-v8": "3.2.4",
    "allure-commandline": "2.34.1",
    "allure-js-commons": "3.4.1",
    "allure-playwright": "3.4.1",
    "axios-mock-adapter": "2.1.0",
    "commitizen": "4.3.1",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "cross-env": "10.1.0",
    "cz-conventional-changelog": "3.3.0",
    "dotenv": "17.3.1",
    "eslint": "9.37.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-project-structure": "3.13.3",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.0",
    "eslint-plugin-sort-destructure-keys": "2.0.0",
    "globals": "15.15.0",
    "jsdom": "29.0.1",
    "orval": "8.6.2",
    "prettier": "3.6.2",
    "rollup-plugin-visualizer": "6.0.5",
    "sass": "1.80.5",
    "semantic-release": "24.2.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.0",
    "vite": "7.3.1",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.33.0"
}
